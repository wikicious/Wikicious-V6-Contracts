# ─── Wikicious V6 — Contracts .env.example ────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git. It is already in .gitignore.

# Your deployer wallet private key (without 0x prefix)
DEPLOYER_PRIVATE_KEY=your_private_key_here

# Alchemy RPC endpoints
ALCHEMY_ARBITRUM_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
ALCHEMY_SEPOLIA_URL=https://arb-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Tenderly (optional – for simulation before mainnet)
TENDERLY_RPC_URL=https://arbitrum.gateway.tenderly.co/YOUR_TENDERLY_KEY

# Arbiscan API key for contract verification
ETHERSCAN_API_KEY=your_arbiscan_api_key_here
